APP_PORT=3000
MINIO_API_PORT=9000
MINIO_ADMIN_PORT=9001

POSTGRES_USER=hapuk
POSTGRES_PASSWORD=
POSTGRES_DB=hapuk

POSTGRES_STORAGE=./pg-data
MINIO_STORAGE=./minio-data

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5433/hapuk

# Better Auth
BETTER_AUTH_SECRET=            # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=invoices@hapuk.io

# File storage (MinIO / S3-compatible — signatures & PDFs)
# Defaults below target the local MinIO in docker-compose.dev.yml.
#
# Production (bundled MinIO in docker-compose.yml):
#   - Set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY to strong, non-default values
#     (these become the MinIO root user/password).
#   - Set S3_ENDPOINT to the PUBLIC, browser-reachable, TLS URL that fronts MinIO's
#     :9000 API (e.g. https://storage.hapuk.io) — NOT http://minio:9000. Presigned
#     PUTs and public GET URLs are handed to the browser, so it must resolve this host.
#
# To use real AWS S3 instead: leave S3_ENDPOINT unset and use real IAM credentials.
AWS_REGION=eu-central-1
S3_BUCKET=hapuk-uploads
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://localhost:9000   # dev: local MinIO. prod: https://storage.hapuk.io
