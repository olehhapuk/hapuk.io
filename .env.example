# Production deployment variables
#
# TLS/ingress is handled by a separate, shared Caddy instance (see
# webdev/docker/caddy + this repo's Caddyfile) — nothing here configures it.
# DNS for hapuk.io and storage.hapuk.io must point at the host before that
# Caddy starts, so it can provision Let's Encrypt certs.

POSTGRES_USER=hapuk
POSTGRES_PASSWORD=
POSTGRES_DB=hapuk
POSTGRES_STORAGE=./pg-data
MINIO_STORAGE=./minio-data

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hapuk

# Better Auth
BETTER_AUTH_SECRET=            # openssl rand -base64 32
BETTER_AUTH_URL=https://hapuk.io   # public app URL, fronted by the shared Caddy

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=invoices@hapuk.io

# File storage (MinIO / S3-compatible — signatures & PDFs)
# Defaults below target the local MinIO in docker-compose.dev.yml.
#
# Production (bundled MinIO in docker-compose.yml, fronted by the shared Caddy at
# storage.hapuk.io):
#   - Set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY to strong, non-default values
#     (these become the MinIO root user/password).
#   - Set S3_ENDPOINT to https://storage.hapuk.io — NOT http://minio:9000. Presigned
#     PUTs and public GET URLs are handed to the browser, so it must resolve this
#     host; the shared Caddy is what makes it TLS + reachable.
#
# To use real AWS S3 instead: leave S3_ENDPOINT unset, use real IAM credentials, and
# drop the storage.hapuk.io site block from Caddyfile.
AWS_REGION=eu-central-1
S3_BUCKET=hapuk-uploads
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://localhost:9000   # dev: local MinIO. prod: https://storage.hapuk.io
