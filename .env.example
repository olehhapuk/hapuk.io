POSTGRES_USER=hapuk
POSTGRES_PASSWORD=
POSTGRES_DB=hapuk

POSTGRES_STORAGE=./pg-data
MINIO_STORAGE=./minio-data

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5433/hapuk

# Better Auth
BETTER_AUTH_SECRET=            # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=invoices@hapuk.io

# File storage (S3 — signatures & PDFs)
# Defaults below target the local MinIO in docker-compose.dev.yml.
# For production AWS S3: use real credentials and leave S3_ENDPOINT unset.
AWS_REGION=eu-central-1
S3_BUCKET=hapuk-uploads
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://localhost:9000   # S3-compatible endpoint (MinIO/R2); unset for real AWS S3
